# @codex-tts 2026-04-22 -- Copy this file to `.agents/voice/voice.env` and
# adjust the values for the current host and remote endpoints.

MOTLIE_VOICE_BUILD_PROFILE=release
MOTLIE_VOICE_ACCELERATION=auto

PIPER_ARTIFACT_ROOT="$HOME/.cache/huggingface/hub"
QWEN3_TTS_CPP_ARTIFACT_ROOT="/tmp/qwen3-tts-models"
WHISPER_ARTIFACT_ROOT="$HOME/.cache/huggingface/hub"
SHERPA_ARTIFACT_ROOT="$HOME/.cache/huggingface/hub"
MOONSHINE_ARTIFACT_ROOT="$HOME/.cache/huggingface/hub"
MOTLIE_VOICE_REFERENCE_ROOT="$REPO_ROOT/artifacts/voice-references"

MOTLIE_VOICE_PLAYBACK_ENDPOINT=motliehost
MOTLIE_VOICE_CAPTURE_ENDPOINT=motliehost

MOTLIE_ENDPOINT_MOTLIEHOST_KIND=ssh
MOTLIE_ENDPOINT_MOTLIEHOST_SSH_TARGET=motliehost
MOTLIE_ENDPOINT_MOTLIEHOST_PLAY_CMD=/opt/homebrew/bin/play -t wav -
MOTLIE_ENDPOINT_MOTLIEHOST_RECORD_CMD=/opt/homebrew/bin/rec -q -c 1 -r 16000 -b 16 -e signed-integer -t wav -

MOTLIE_ENDPOINT_LOCAL_LINUX_KIND=local
MOTLIE_ENDPOINT_LOCAL_LINUX_PLAY_CMD=play -t wav -
MOTLIE_ENDPOINT_LOCAL_LINUX_RECORD_CMD=rec -q -c 1 -r 16000 -b 16 -e signed-integer -t wav -
