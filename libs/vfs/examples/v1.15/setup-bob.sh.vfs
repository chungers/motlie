provision bob /tmp/motlie-vfs-bob.vsock_5000 2001 2001
mount bob bob-home=/home/bob,/tmp/motlie-vfs-demo/bob-home bob-workspace=/workspace,/tmp/motlie-vfs-demo/bob-workspace
use bob
layer credentials 0
layer workspace 10
putattr credentials bob-home /.ssh/authorized_keys 2001 2001 600 ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIExample bob@dev
put workspace bob-workspace /README.md Bob workspace mounted from the host over the v1.15 Vz virtio-socket bridge.
