[Unit]
Description=motlie-vfs guest filesystem mounter (v1.15 Vz)
After=network-online.target local-fs.target
Wants=network-online.target
Before=ssh.service

[Service]
Type=simple
ExecStart=/usr/local/bin/motlie-vfs-guest-v1_15 /etc/motlie-vfs/mounts.yaml
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
