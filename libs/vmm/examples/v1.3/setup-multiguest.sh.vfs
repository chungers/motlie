# v1.3 combined demo data for one repl_host process managing two guests

provision alice /tmp/motlie-vmm-alice.vsock_5000 1000 1000
mount alice alice-home=/home/alice,/tmp/motlie-vmm-demo/alice-home alice-workspace=/workspace,/tmp/motlie-vmm-demo/alice-workspace alice-agent-state=/agent-state,/tmp/motlie-vmm-demo/alice-agent-state

use alice
layer credentials 0
layer workspace 10

mkdir credentials alice-agent-state /codex 700
mkdir credentials alice-agent-state /codex/sqlite 700
mkdir credentials alice-agent-state /claude 700
mkdir credentials alice-agent-state /claude-code 700
put workspace alice-agent-state /README.md Dedicated read-write agent-state layer for Codex and Claude lives here.
put workspace alice-workspace /README.md Alice workspace mounted from the host.
ls alice-home
ls alice-workspace
ls alice-agent-state

provision bob /tmp/motlie-vmm-bob.vsock_5000 1001 1001
mount bob bob-home=/home/bob,/tmp/motlie-vmm-demo/bob-home bob-workspace=/workspace,/tmp/motlie-vmm-demo/bob-workspace bob-agent-state=/agent-state,/tmp/motlie-vmm-demo/bob-agent-state

use bob
layer credentials 0
layer workspace 10

mkdir credentials bob-agent-state /codex 700
mkdir credentials bob-agent-state /codex/sqlite 700
mkdir credentials bob-agent-state /claude 700
mkdir credentials bob-agent-state /claude-code 700
put workspace bob-agent-state /README.md Dedicated read-write agent-state layer for Codex and Claude lives here.
put workspace bob-workspace /README.md Bob workspace mounted from the host.
ls bob-home
ls bob-workspace
ls bob-agent-state
