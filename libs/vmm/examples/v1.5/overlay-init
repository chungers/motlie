#!/bin/sh
# overlay-init — PID 1 init script for squashfs + ext4 overlay boot.
#
# Kernel cmdline: init=/sbin/overlay-init overlay_root=vdb

die() { echo "overlay-init FATAL: $*" > /dev/kmsg 2>/dev/null; echo "$*"; exec /bin/sh; }
log() { echo "overlay-init: $*" > /dev/kmsg 2>/dev/null; }

log "starting"

# 1. Mount pseudo-filesystems
/bin/mount -t proc proc /proc            || die "mount /proc failed"
/bin/mount -t sysfs sysfs /sys           || die "mount /sys failed"
/bin/mount -t devtmpfs devtmpfs /dev 2>/dev/null || true

log "pseudo-fs mounted"

# Parse overlay_root= from kernel cmdline
OVERLAY_DEV=""
for arg in $(cat /proc/cmdline); do
    case "$arg" in
        overlay_root=*) OVERLAY_DEV="/dev/${arg#overlay_root=}" ;;
    esac
done

if [ -z "$OVERLAY_DEV" ]; then
    die "no overlay_root= on kernel cmdline"
fi
log "overlay dev=$OVERLAY_DEV"

# 2. Writable workspace (root is read-only squashfs)
/bin/mount -t tmpfs tmpfs /mnt                              || die "mount tmpfs failed"
/bin/mkdir -p /mnt/lower /mnt/upper /mnt/merged             || die "mkdir failed"
log "tmpfs workspace ready"

# 3. Bind the current squashfs root as lower layer
/bin/mount --bind / /mnt/lower                              || die "bind / failed"

# 4. Mount ext4 overlay device
log "mounting $OVERLAY_DEV"
/bin/mount -t ext4 "$OVERLAY_DEV" /mnt/upper                || die "mount ext4 failed"
/bin/mkdir -p /mnt/upper/upper /mnt/upper/work

# 5. Stack overlayfs
/bin/mount -t overlay overlay \
    -o lowerdir=/mnt/lower,upperdir=/mnt/upper/upper,workdir=/mnt/upper/work \
    /mnt/merged                                             || die "mount overlay failed"
log "overlayfs mounted"

if [ -x /mnt/merged/sbin/openrc ]; then
    log "detected OpenRC root; mounting pseudo-fs inside overlay"
    /bin/mkdir -p /mnt/merged/proc /mnt/merged/sys /mnt/merged/dev
    /bin/mount -t proc proc /mnt/merged/proc                 || die "mount overlay /proc failed"
    /bin/mount -t sysfs sysfs /mnt/merged/sys                || die "mount overlay /sys failed"
    /bin/mount -t devtmpfs devtmpfs /mnt/merged/dev 2>/dev/null \
        || /bin/mount --bind /dev /mnt/merged/dev            || die "mount overlay /dev failed"
    log "execing OpenRC init via chroot"
    if [ -x /usr/sbin/chroot ]; then
        exec /usr/sbin/chroot /mnt/merged /sbin/init "$@"
    fi
    exec chroot /mnt/merged /sbin/init "$@"
fi

# 6. Unmount pseudo-fs (the real init will remount them after pivot).
# Busybox-based roots can hold transient references during PID 1 shell setup;
# lazy unmount keeps the pivot path portable across Ubuntu/systemd and
# Alpine/OpenRC without changing the guest contract.
log "preparing pivot"
/bin/umount -l /proc 2>/dev/null || log "lazy umount /proc skipped"
/bin/umount -l /sys 2>/dev/null || log "lazy umount /sys skipped"
# /dev stays — pivot_root needs it

# 7. Pivot root
log "pivoting root"
cd /mnt/merged                                              || die "cd merged failed"
/bin/mkdir -p old_root
if command -v pivot_root >/dev/null 2>&1; then
    pivot_root . old_root                                   || die "pivot_root failed"
elif [ -x /sbin/pivot_root ]; then
    /sbin/pivot_root . old_root                             || die "/sbin/pivot_root failed"
else
    die "pivot_root command not found"
fi
log "pivot complete"

# 8. Clean up old mounts
/bin/umount -l /old_root 2>/dev/null || true

# 9. Exec real init
log "execing /sbin/init"
exec /sbin/init "$@"
