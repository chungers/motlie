# CH adaptation of the common v1.5 guest backend contract.
# launch-ch.sh renders this schema into the per-guest runtime overlay because
# CH keeps per-guest dynamic seed data outside the immutable squashfs.

MOTLIE_BACKEND=ch
MOTLIE_VFS_TRANSPORT=vsock
MOTLIE_VFS_HOST_CID=2
MOTLIE_VFS_PORT=5000
MOTLIE_VFS_CONNECT_TIMEOUT_MS=60000
MOTLIE_VFS_CONNECT_RETRY_MS=250
MOTLIE_NET_BACKEND=ch-vhost-user
MOTLIE_SSH_VSOCK_PORT=2222
