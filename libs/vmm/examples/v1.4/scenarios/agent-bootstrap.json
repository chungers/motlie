{
  "name": "agent-bootstrap",
  "description": "Boot alice and verify baseline agent guest prerequisites: VFS mounts, passwordless sudo, preinstalled git, Codex CLI, outbound internet, and apt package-index refresh.",
  "steps": [
    { "action": "boot", "guest": "alice" },
    { "action": "ready", "guest": "alice" },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'test -f /workspace/README.md && echo WORKSPACE_OK'",
      "timeout_ms": 10000,
      "expect": { "exit_code": 0, "stdout_contains": "WORKSPACE_OK" }
    },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'sudo -n true && echo SUDO_OK'",
      "timeout_ms": 10000,
      "expect": { "exit_code": 0, "stdout_contains": "SUDO_OK" }
    },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'git --version | grep -q \"^git version \" && echo GIT_OK'",
      "timeout_ms": 10000,
      "expect": { "exit_code": 0, "stdout_contains": "GIT_OK" }
    },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'codex --version | grep -q \"^codex-cli \" && echo CODEX_OK'",
      "timeout_ms": 10000,
      "expect": { "exit_code": 0, "stdout_contains": "CODEX_OK" }
    },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'code=$(curl -s -o /dev/null -w \"%{http_code}\" https://example.com); test \"$code\" = 200 && echo HTTPS_OK'",
      "timeout_ms": 20000,
      "expect": { "exit_code": 0, "stdout_contains": "HTTPS_OK" }
    },
    {
      "action": "exec",
      "guest": "alice",
      "command": "/bin/sh -lc 'for attempt in 1 2 3; do sudo -n apt-get update >/tmp/motlie-vmm-apt-update.log 2>&1 && echo APT_OK && exit 0; sleep 2; done; exit 1'",
      "timeout_ms": 60000,
      "expect": { "exit_code": 0, "stdout_contains": "APT_OK" }
    },
    { "action": "shutdown", "guest": "alice" }
  ]
}
