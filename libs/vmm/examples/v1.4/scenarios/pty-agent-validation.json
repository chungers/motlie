{
  "name": "pty-agent-validation",
  "description": "Boot alice, drive the interactive shell over PTY, validate apt refresh in-band, and capture the Codex TUI startup in the recorded terminal session.",
  "steps": [
    { "action": "boot", "guest": "alice" },
    { "action": "ready", "guest": "alice" },
    {
      "action": "pty_open",
      "guest": "alice",
      "session": "alice-shell",
      "term": "xterm-256color",
      "cols": 100,
      "rows": 30,
      "timeout_ms": 10000
    },
    {
      "action": "pty_expect",
      "session": "alice-shell",
      "contains": "Start tmux session?",
      "timeout_ms": 20000
    },
    {
      "action": "pty_expect_screen",
      "session": "alice-shell",
      "contains": "Start tmux session?",
      "timeout_ms": 2000
    },
    { "action": "pty_send_line", "session": "alice-shell", "text": "n" },
    {
      "action": "pty_expect",
      "session": "alice-shell",
      "contains": "alice@motlie-alice",
      "timeout_ms": 10000
    },
    {
      "action": "pty_send_line",
      "session": "alice-shell",
      "text": "idle=0; for _ in $(seq 1 60); do if ! pgrep -x apt >/dev/null 2>&1 && ! pgrep -x apt-get >/dev/null 2>&1 && ! pgrep -x dpkg >/dev/null 2>&1 && ! pgrep -x unattended-upgr >/dev/null 2>&1 && ! pgrep -x unattended-upgrade >/dev/null 2>&1; then idle=$((idle+1)); if [ \"$idle\" -ge 5 ]; then echo PKG_IDLE_OK; break; fi; else idle=0; fi; sleep 1; done; sudo -n apt-get update && echo APT_STATUS:0 || echo APT_STATUS:1"
    },
    {
      "action": "pty_expect",
      "session": "alice-shell",
      "contains": "PKG_IDLE_OK",
      "timeout_ms": 65000
    },
    {
      "action": "pty_expect",
      "session": "alice-shell",
      "contains": "APT_STATUS:0",
      "timeout_ms": 120000
    },
    {
      "action": "pty_expect_screen",
      "session": "alice-shell",
      "contains": "APT_STATUS:0",
      "timeout_ms": 2000
    },
    {
      "action": "pty_snapshot",
      "session": "alice-shell",
      "name": "after-apt-update"
    },
    { "action": "pty_send_line", "session": "alice-shell", "text": "codex" },
    {
      "action": "pty_expect_screen",
      "session": "alice-shell",
      "contains": "1. Sign in with ChatGPT",
      "timeout_ms": 20000
    },
    {
      "action": "pty_expect_screen",
      "session": "alice-shell",
      "contains": "Press Enter to continue",
      "timeout_ms": 20000
    },
    {
      "action": "pty_snapshot",
      "session": "alice-shell",
      "name": "codex-welcome"
    }
  ]
}
